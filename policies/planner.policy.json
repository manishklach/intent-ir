{
  "allowed_tools": [
    "repo.scan",
    "artifact.write",
    "trace.emit"
  ],
  "denied_tools": [
    "shell.exec",
    "file.delete",
    "network.post",
    "secrets.read"
  ],
  "max_budget": {
    "memory_mb": 1024,
    "tokens": 8000,
    "wall_ms": 8000
  },
  "require_asserts": false,
  "require_commit": false
}
