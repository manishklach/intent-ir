{
  "agent_id": "auditor-agent",
  "workflow": [
    { "type": "init", "name": "safe_execution" },
    { "type": "log", "message": "Starting safe tool call sequence" },
    { "type": "assert", "condition": "tool_is_whitelisted('read_file')" },
    { "type": "tool", "name": "read_file", "args": ["config.yaml"] },
    { "type": "commit", "data": "success" }
  ]
}
