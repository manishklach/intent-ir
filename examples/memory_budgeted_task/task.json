{
  "agent_id": "mem-constrained",
  "workflow": [
    { "type": "init", "name": "process_large_data" },
    { "type": "budget", "amount": 128, "currency": "MB" },
    { "type": "log", "message": "Memory budget set to 128MB" },
    { "type": "tool", "name": "process", "args": ["data.bin"] },
    { "type": "assert", "condition": "mem_usage < 128" }
  ]
}
